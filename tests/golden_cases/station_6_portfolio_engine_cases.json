{
  "station": "portfolio_engine",
  "version": "v1.0",
  "cases": [
    {
      "test_case_id": "TC_ENG_001",
      "description": "Feasibility failure when requested increase cannot be constructed without violating cash restriction.",
      "input_payload": {
        "station_5_output": {
          "run_id": "run_eng_001",
          "strategy_regime": "BUILDUP",
          "risk_multiplier_override": 1.0,
          "target_allocation_adjustments": [
            {
              "asset_id": "SMH",
              "action": "INCREASE",
              "confidence_score": 0.78
            }
          ]
        },
        "portfolio_state": {
          "portfolio_value": 100000.0,
          "cash": 500.0,
          "cash_quota": 0.005,
          "positions": [
            {
              "asset_id": "SMH",
              "market_value": 25000.0,
              "current_weight": 0.25
            }
          ]
        },
        "constraints": {
          "cash_must_not_be_negative": true
        }
      },
      "expected_rule_id": "VAL_ENG_001",
      "expected_engine_status": "PORTFOLIO_CONSTRUCTION_FAILED",
      "expected_system_status": "NO_NEW_ACTIONS",
      "expected_pipeline_action": "STOP_BEFORE_STATION_7",
      "expected_market_action": "none",
      "expected_audit_contains": "Insufficient cash to construct requested target allocation"
    },
    {
      "test_case_id": "TC_ENG_001B",
      "description": "Technical error when portfolio value is stale or inconsistent with position data.",
      "input_payload": {
        "station_5_output": {
          "run_id": "run_eng_001b",
          "strategy_regime": "BUILDUP",
          "risk_multiplier_override": 1.0,
          "target_allocation_adjustments": [
            {
              "asset_id": "SMH",
              "action": "INCREASE",
              "confidence_score": 0.78
            }
          ]
        },
        "portfolio_state": {
          "portfolio_value": 100000.0,
          "portfolio_value_timestamp_status": "STALE",
          "cash": 20000.0,
          "positions_total_market_value": 95000.0,
          "cash_plus_positions_value": 115000.0
        }
      },
      "expected_rule_id": "VAL_ENG_003",
      "expected_engine_status": "TECHNICAL_ERROR",
      "expected_system_status": "SAFE_HOLD",
      "expected_pipeline_action": "STOP",
      "expected_market_action": "none",
      "expected_audit_contains": "portfolio value"
    },
    {
      "test_case_id": "TC_ENG_002",
      "description": "Invalid engine output when target weights plus cash quota do not sum to 1.0 within tolerance.",
      "input_payload": {
        "engine_output": {
          "run_id": "run_eng_002",
          "target_weights": {
            "SPY": 0.30,
            "QQQ": 0.25,
            "SMH": 0.20
          },
          "cash_quota_after_rebalance": 0.235,
          "total_weight_sum": 0.985
        },
        "tolerance": 0.0001
      },
      "expected_rule_id": "VAL_ENG_002",
      "expected_engine_status": "TECHNICAL_ERROR",
      "expected_system_status": "SAFE_HOLD",
      "expected_pipeline_action": "STOP",
      "expected_market_action": "none",
      "expected_audit_contains": "Target allocation sum equals 0.985"
    }
  ]
}
