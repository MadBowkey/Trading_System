  "cases": [
    {
      "test_case_id": "TC_BLV_003",
      "description": "Duplicate asset with INCREASE vs LIQUIDATE must block the pipeline.",
      "input_payload": {
        "schema_version": "llm_meta_manager_output.v1",
        "run_id": "run_blv_003",
        "strategy_regime": "BUILDUP",
        "risk_multiplier_override": 1.0,
        "allow_new_positions": true,
        "allow_add_ons": true,
        "allow_risk_increase": true,
        "target_allocation_adjustments": [
          {
            "asset_id": "SMH",
            "action": "INCREASE",
            "strategy_class": "TREND_PULLBACK",
            "confidence_score": 0.78,
            "asset_risk_multiplier_override": null,
            "reason_codes": ["BULLISH_TREND_CONFIRMED"],
            "reasoning_short": "Increase SMH."
          },
          {
            "asset_id": "SMH",
            "action": "LIQUIDATE",
            "strategy_class": "RISK_CONTROL",
            "confidence_score": 0.74,
            "asset_risk_multiplier_override": null,
            "reason_codes": ["PROACTIVE_DERISKING"],
            "reasoning_short": "Liquidate SMH."
          }
        ],
        "reasoning_short": "Conflicting duplicate asset actions."
      },
      "expected_rule_id": "VAL_BLV_001",
      "expected_validator_status": "BLOCKED",
      "expected_system_status": "SAFE_HOLD",
      "expected_pipeline_action": "STOP",
      "expected_audit_contains": "INCREASE vs LIQUIDATE"
    },
    {
      "test_case_id": "TC_BLV_004",
