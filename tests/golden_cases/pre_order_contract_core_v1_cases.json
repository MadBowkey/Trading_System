            "decision_ref": "decision_run_pre_006",
            "short_authorization_ref": "short_auth_TC_PRE_006"
          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_INVALID"
      }
    },
    {
      "test_case_id": "TC_PRE_007",
