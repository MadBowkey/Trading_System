            "market_data_snapshot_ref": "mds_run_pre_008",
            "portfolio_state_ref": "ps_run_pre_008",
            "decision_ref": "decision_run_pre_008"
          },
          {
            "proposed_order_ref": "TC_PRE_008_PROPOSED_ORDER_002",
