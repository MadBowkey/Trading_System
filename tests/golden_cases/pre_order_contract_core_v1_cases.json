{
  "spec": "pre_order_proposed_order_contract_core_v1",
  "version": "v1.0",
  "architecture": "v1.6.1",
  "cases": [
    {
      "test_case_id": "TC_PRE_001",
      "title": "Gültige LIMIT-BUY Order",
      "input_condition": "Vollständige ProposedOrder mit side BUY, order_type LIMIT, limit_price gesetzt und allen Pflichtfeldern.",
      "input_payload": {
        "proposed_order_list": [
          {
            "proposed_order_ref": "TC_PRE_001_PROPOSED_ORDER_001",
            "run_id": "run_pre_001",
            "asset_id": "SPY",
            "symbol": "SPY",
            "side": "BUY",
            "order_type": "LIMIT",
            "quantity": "10",
            "limit_price": "500.00",
            "allow_short": false,
            "proposed_at": "2026-05-18T08:30:00.000Z",
            "market_data_snapshot_ref": "mds_run_pre_001",
            "portfolio_state_ref": "ps_run_pre_001",
            "decision_ref": "decision_run_pre_001"
          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_READY",
        "forward_to_station_8": true,
        "proposed_order_list_unchanged": true
      }
    },
    {
      "test_case_id": "TC_PRE_002",
      "title": "MARKET mit limit_price",
      "input_condition": "order_type MARKET, limit_price gesetzt.",
      "input_payload": {
        "proposed_order_list": [
          {
            "proposed_order_ref": "TC_PRE_002_PROPOSED_ORDER_001",
            "run_id": "run_pre_002",
            "asset_id": "SPY",
            "symbol": "SPY",
            "side": "BUY",
            "order_type": "MARKET",
            "quantity": "10",
            "limit_price": "500.00",
            "allow_short": false,
            "proposed_at": "2026-05-18T08:30:00.000Z",
            "market_data_snapshot_ref": "mds_run_pre_002",
            "portfolio_state_ref": "ps_run_pre_002",
            "decision_ref": "decision_run_pre_002"
          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_INVALID",
        "invalid_fields_contains": ["limit_price"]
      }
    },
    {
      "test_case_id": "TC_PRE_003",
      "title": "LIMIT ohne limit_price",
      "input_condition": "order_type LIMIT, limit_price null.",
      "input_payload": {
        "proposed_order_list": [
          {
            "proposed_order_ref": "TC_PRE_003_PROPOSED_ORDER_001",
            "run_id": "run_pre_003",
            "asset_id": "SPY",
            "symbol": "SPY",
            "side": "BUY",
            "order_type": "LIMIT",
            "quantity": "10",
            "limit_price": null,
            "allow_short": false,
            "proposed_at": "2026-05-18T08:30:00.000Z",
            "market_data_snapshot_ref": "mds_run_pre_003",
            "portfolio_state_ref": "ps_run_pre_003",
            "decision_ref": "decision_run_pre_003"
          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_INVALID",
        "invalid_or_missing_fields_contains": ["limit_price"]
      }
    },
    {
      "test_case_id": "TC_PRE_004",
      "title": "Ungültige quantity",
      "input_condition": "quantity kleiner gleich 0, Float statt Decimal-String oder ungültiges Format.",
      "input_payload": {
        "proposed_order_list": [
          {
