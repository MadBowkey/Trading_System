            "portfolio_state_ref": "ps_run_pre_004",
            "decision_ref": "decision_run_pre_004"
          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_INVALID",
        "invalid_fields_contains": ["quantity"]
      }
    },
    {
      "test_case_id": "TC_PRE_005",
      "title": "Fehlende Herkunftsreferenz",
      "input_condition": "Weder decision_ref noch position_change_plan_ref vorhanden.",
