          }
        ]
      },
      "expected_result": {
        "contract_status": "CONTRACT_INVALID",
        "reason_contains": "Traceability"
      }
    },
    {
      "test_case_id": "TC_PRE_006",
      "title": "Unvollständige Short-Autorisierung",
